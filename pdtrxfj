#include "BluetoothSerial.h"

BluetoothSerial SerialBT;

const int trigPin = 5;
const int echoPin = 18;
const int relePin = 23;

unsigned long tiempoAnterior = 0;
const int intervalo = 800;

float distancia = 0;

bool sistemaActivo = false;
bool modoManual = false;

float medirDistancia() {

  long duracion;

  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duracion = pulseIn(echoPin, HIGH, 30000);

  if (duracion == 0) {
    return -1;
  }

  return duracion * 0.034 / 2;
}

void setup() {

  Serial.begin(115200);

  SerialBT.begin("ESP32_Distancia");

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  pinMode(relePin, OUTPUT);

  digitalWrite(relePin, HIGH); // apagado inicial
}

void loop() {

  // RECEPCIÓN DE COMANDOS BLUETOOTH
  if (SerialBT.available()) {

    char dato = SerialBT.read();

    // ACTIVAR AUTOMÁTICO
    if (dato == 'S') {

      sistemaActivo = true;
      modoManual = false;

      Serial.println("Modo automatico ACTIVADO");
    }

    // APAGAR TODO
    else if (dato == 'P') {

      sistemaActivo = false;
      modoManual = false;

      digitalWrite(relePin, HIGH);

      Serial.println("Sistema APAGADO");
    }

    // PRENDER MANUAL
    else if (dato == 'A') {

      modoManual = true;

      digitalWrite(relePin, LOW);

      Serial.println("Foco PRENDIDO manual");
    }

    // APAGAR MANUAL
    else if (dato == 'B') {

      modoManual = true;

      digitalWrite(relePin, HIGH);

      Serial.println("Foco APAGADO manual");
    }
  }

  // TODO APAGADO
  if (!sistemaActivo && !modoManual) {

    digitalWrite(relePin, HIGH);

    return;
  }

  // MODO MANUAL
  if (modoManual) {
    return;
  }

  // FUNCIONAMIENTO AUTOMÁTICO
  if (millis() - tiempoAnterior >= intervalo) {

    tiempoAnterior = millis();

    float nueva = medirDistancia();

    if (nueva > 0 && nueva < 400) {

      // FILTRO SUAVE
      distancia = (distancia * 0.8) + (nueva * 0.2);

      // ENVÍA A APP INVENTOR
      SerialBT.println(String(distancia, 1) + " cm");

      // MUESTRA EN MONITOR SERIAL
      Serial.print("Distancia: ");
      Serial.print(distancia, 1);
      Serial.println(" cm");

      // CONTROL DEL RELÉ
      if (distancia > 20) {

        digitalWrite(relePin, LOW);

        Serial.println("FOCO PRENDIDO");
      }
      else {

        digitalWrite(relePin, HIGH);

        Serial.println("FOCO APAGADO");
      }
    }
  }
}
